# Copy this file to ".env" and fill in your values. The build reads .env
# automatically; .env is git-ignored so credentials stay off the command line
# and out of the repo. Real exported env vars override these.
#
# No "export", no quotes needed. A leading ~/ is expanded to your home dir.

# Your 10-character Apple Team ID (shown on the Developer ID cert and at
# developer.apple.com -> Membership).
APPLE_TEAM_ID=YOURTEAMID

# --- Option A: App Store Connect API key (recommended) ---------------------
APPLE_API_KEY=~/.appstoreconnect/AuthKey_XXXXXXXXXX.p8
APPLE_API_KEY_ID=XXXXXXXXXX
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000

# --- Option B: Apple ID + app-specific password (use instead of A) ---------
# APPLE_ID=steve@stevenowicki.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
